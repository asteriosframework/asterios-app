{% extends "layout/main.twig" %}

{% block content %}

    {% include "components/navbar.twig" %}

    <!-- HERO -->
    <section class="py-[120px] text-center">
        <div class="max-w-4xl mx-auto px-4">
            <h1 class="hero-title">{{ headline }}</h1>

            <p class="hero-text">
                The {{ appName }} Framework is a simple and flexible PHP 8.+ framework...
            </p>

            <div class="mt-4">
                {% include "components/button.twig" with { label: "Get started" } %}
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="py-20">
        <div class="container-app">
            <div class="grid md:grid-cols-3 gap-6">

                {% include "components/card.twig" with {
                    title: "⚡ Fast",
                    content: "Optimized core structure for maximum performance and minimal latency."
                } %}

                {% include "components/card.twig" with {
                    title: "🧩 Modular",
                    content: "Clean architecture with clear separation of routing, views, and logic."
                } %}

                {% include "components/card.twig" with {
                    title: "🔒 Secure",
                    content: "Modern security standards and best practices are directly integrated."
                } %}

            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 text-center">
        <div class="max-w-3xl mx-auto px-4">
            <h2 class="mb-3 text-3xl font-semibold">Ready to get started?</h2>

            <p class="mb-4 text-gray-500">
                Build your next project with {{ appName }}.
            </p>

            {% include "components/button.twig" with { label: "Start now" } %}
        </div>
    </section>

{% endblock %}